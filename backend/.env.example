# Non-secret local config. Prefer putting API keys in secrets.local.env.
API_PROVIDER=api_football
API_BASE_HOST=v3.football.api-sports.io
API_ENDPOINT_LEAGUES=/leagues
API_ENDPOINT_TEAMS=/teams
API_ENDPOINT_FIXTURES=/fixtures
API_ENDPOINT_FIXTURE_DETAIL=/fixtures
API_ENDPOINT_QUOTA=/status
API_ENDPOINT_HEADTOHEAD=/fixtures/headtohead
API_ENDPOINT_TEAM_STATISTICS=/teams/statistics
API_ENDPOINT_ODDS=/odds
API_ENDPOINT_LINEUPS=/fixtures/lineups
API_ENDPOINT_INJURIES=/injuries
DATABASE_URL=sqlite+aiosqlite:///./data/football.db
REDIS_URL=redis://localhost:6379
# Local default: skip Redis connect attempts (use in-memory cache).
REDIS_ENABLED=false
LOG_LEVEL=INFO
LOG_DIR=logs
SCHEDULER_TIMEZONE=Asia/Shanghai
PRE_MATCH_WINDOW_HOURS=2
CLEANUP_DAYS=7
HTTP_VERIFY_SSL=false
LOCAL_FIRST=true
# 0 = use kickoff-based refresh policy (recommended)
ANALYSIS_REFRESH_TTL_SECONDS=0
# Cap official API enrichment time so the UI does not hit axios timeout.
ANALYSIS_API_BUDGET_SECONDS=12
# ML: accumulate local FT labels from now; auto-train & switch when enough.
ML_MIN_TRAIN_SAMPLES=30
ML_AUTO_TRAIN=true
