# Copy this file to secrets.local.env and fill in your keys.
# secrets.local.env is gitignored and must never be committed.

# Official API-Sports key (recommended)
API_SPORTS_KEY=your_api_sports_key_here

# Optional RapidAPI fallback (used only when API_SPORTS_KEY is empty)
# RAPIDAPI_KEY=your_rapidapi_key_here
# RAPIDAPI_HOST=v3.football.api-sports.io

ADMIN_API_KEY=football-analytics-admin
