# Local IDE
.idea/

# Runtime logs (backend writes under backend/logs/; ignore any repo-root logs too)
logs/

# Local secrets (belt-and-suspenders; also ignored under backend/)
**/.env
**/secrets.local.env
**/*.local.env
!**/.env.example
!**/secrets.local.env.example

# Trained model artifacts (regenerate via `python manage.py train-model`)
backend/data/models/
