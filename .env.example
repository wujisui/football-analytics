# Official API-Football via RapidAPI: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=cae5c34fd4msh12319397ae471e2p1e17a0jsnf0a90e604c6b
RAPIDAPI_HOST=v3.football.api-sports.io
API_PROVIDER=api_football
API_ENDPOINT_LEAGUES=/leagues
API_ENDPOINT_TEAMS=/teams
API_ENDPOINT_FIXTURES=/fixtures
API_ENDPOINT_FIXTURE_DETAIL=/fixtures
API_ENDPOINT_QUOTA=/status
API_ENDPOINT_HEADTOHEAD=/fixtures/headtohead
